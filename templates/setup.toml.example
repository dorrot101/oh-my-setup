# oh-my-setup 마스터 설정 파일
# 이 파일을 ~/dotfiles/setup.toml 로 복사하여 사용하세요.

[meta]
version = "1"
machine_name = ""  # 빈 값이면 hostname 자동 사용
profile = ""       # laptop, server 등 (비어있으면 프로파일 미적용)

[git]
remote = "git@github.com:username/dotfiles.git"
branch = "main"
auto_commit = true
auto_push = true

[update]
check_on_shell_open = true
check_interval_days = 1
auto_apply = false

[modules]
enabled = [
  "git",
  "zsh",
]

[brew]
bundle_file = "Brewfile"
cleanup = false

[link]
strategy = "symlink"
backup = true
backup_dir = "~/.oh-my-setup-backup"

[macos]
apply_defaults = false
defaults_file = "macos-defaults.sh"
